# Neon Postgres — see docs/00-human-setup-tasks.md and docs/02-database-schema.md
DATABASE_URL="postgresql://<user>:<pass>@<endpoint>-pooler.<region>.aws.neon.tech/<db>?sslmode=require"
DIRECT_URL="postgresql://<user>:<pass>@<endpoint>.<region>.aws.neon.tech/<db>?sslmode=require"

# Auth
JWT_SECRET="generate-with-openssl-rand-base64-32"
ADMIN_EMAIL="you@example.com"
ADMIN_PASSWORD="set-a-real-password-then-remove-this-var-after-seeding"

# Server
PORT=4000
FRONTEND_ORIGIN="http://localhost:3000"

# LLM (wired in Phase 2)
GEMINI_API_KEY=""
GROQ_API_KEY=""

# Vault (wired in Phase 5)
VAULT_ENCRYPTION_KEY="generate-with-openssl-rand-base64-32"

# Firebase Cloud Messaging (wired in Phase 6)
FIREBASE_SERVICE_ACCOUNT_JSON=""

# cron-job.org shared secret (wired later in Phase 1/6)
CRON_SECRET="generate-a-random-secret"

# Green API / WhatsApp (optional, wired in Phase 6)
GREEN_API_ID_INSTANCE=""
GREEN_API_TOKEN_INSTANCE=""
