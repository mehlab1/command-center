// FinovaSolutions Command Center — Prisma schema
// Source of truth for shape: docs/01-data-model.md
// Connection-string split (DATABASE_URL pooled / DIRECT_URL unpooled): docs/02-database-schema.md

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Auth (not in docs/01-data-model.md — added for Phase 1 single-user login;
// separate from `devs`, which are the managed people/team data, not app users)
// ---------------------------------------------------------------------------

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("users")
}

// ---------------------------------------------------------------------------
// Core domain
// ---------------------------------------------------------------------------

enum ProjectStatus {
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

model Project {
  id          String        @id @default(uuid())
  name        String
  description String?
  category    String?
  status      ProjectStatus @default(ACTIVE)
  deadline    DateTime?
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  tasks     Task[]
  reminders Reminder[]

  @@index([status])
  @@index([deadline])
  @@map("projects")
}

enum EmploymentType {
  PERMANENT
  INTERN
}

model Dev {
  id                String         @id @default(uuid())
  name              String
  designation       String?
  employmentType    EmploymentType @map("employment_type")
  internshipEndDate DateTime?      @map("internship_end_date")
  podId             String?        @map("pod_id")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")

  pod                Pod?             @relation("PodMembers", fields: [podId], references: [id])
  ledPod             Pod?             @relation("PodLead")
  taskAssignees      TaskAssignee[]
  ratingsHistory     RatingsHistory[]
  suggestedQaEntries QaQueueEntry[]   @relation("SuggestedReviewer")
  assignedQaEntries  QaQueueEntry[]   @relation("AssignedReviewer")

  @@index([podId])
  @@map("devs")
}

model Pod {
  id        String   @id @default(uuid())
  name      String
  leadDevId String   @unique @map("lead_dev_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  lead    Dev   @relation("PodLead", fields: [leadDevId], references: [id])
  members Dev[] @relation("PodMembers")

  @@map("pods")
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  BLOCKED
}

model Task {
  id                 String     @id @default(uuid())
  title              String
  description        String?
  notes              String?
  projectId          String?    @map("project_id")
  isPersonal         Boolean    @default(false) @map("is_personal")
  status             TaskStatus @default(TODO)
  deadline           DateTime
  blockerDescription String?    @map("blocker_description")
  revisedDeadline    DateTime?  @map("revised_deadline")
  missedDeadline     Boolean?   @map("missed_deadline")
  needsQa            Boolean    @default(false) @map("needs_qa")
  supersededByTaskId String?    @unique @map("superseded_by_task_id")
  supersedesTaskId   String?    @unique @map("supersedes_task_id")
  rating             Int?
  completedAt        DateTime?  @map("completed_at")
  createdAt          DateTime   @default(now()) @map("created_at")
  updatedAt          DateTime   @updatedAt @map("updated_at")

  project        Project?         @relation(fields: [projectId], references: [id])
  assignees      TaskAssignee[]
  qaQueueEntry   QaQueueEntry?
  ratingsHistory RatingsHistory[]
  reminders      Reminder[]

  // supersededByTaskId / supersedesTaskId are a denormalized pointer pair
  // (docs/01-data-model.md) rather than a single Prisma relation — kept as
  // plain scalar columns, resolved by the service layer, not a self-relation.

  @@index([status])
  @@index([deadline])
  @@index([projectId])
  @@map("tasks")
}

model TaskAssignee {
  taskId String @map("task_id")
  devId  String @map("dev_id")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  dev  Dev  @relation(fields: [devId], references: [id], onDelete: Cascade)

  @@id([taskId, devId])
  @@index([devId])
  @@map("task_assignees")
}

enum QaStatus {
  UNASSIGNED
  ASSIGNED
  PASSED
  SENT_BACK
}

model QaQueueEntry {
  id                     String    @id @default(uuid())
  taskId                 String    @unique @map("task_id")
  status                 QaStatus  @default(UNASSIGNED)
  suggestedReviewerDevId String?   @map("suggested_reviewer_dev_id")
  assignedReviewerDevId  String?   @map("assigned_reviewer_dev_id")
  outcomeNotes           String?   @map("outcome_notes")
  createdAt              DateTime  @default(now()) @map("created_at")
  resolvedAt             DateTime? @map("resolved_at")

  task              Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  // SetNull, not the default NO ACTION: deleting a dev who is a suggested/
  // assigned reviewer somewhere must not block that deletion with a raw FK
  // error — the entry just needs a new reviewer, per the existing pattern of
  // checkDeleteDev warning about open tasks before allowing dev deletion.
  suggestedReviewer Dev? @relation("SuggestedReviewer", fields: [suggestedReviewerDevId], references: [id], onDelete: SetNull)
  assignedReviewer  Dev? @relation("AssignedReviewer", fields: [assignedReviewerDevId], references: [id], onDelete: SetNull)

  @@index([status])
  @@map("qa_queue_entries")
}

model RatingsHistory {
  id        String   @id @default(uuid())
  devId     String   @map("dev_id")
  taskId    String   @map("task_id")
  rating    Int
  onTime    Boolean  @map("on_time")
  createdAt DateTime @default(now()) @map("created_at")

  // No onDelete: Cascade on dev, deliberately — ratings_history is the
  // append-only source for trend charts (docs/01-data-model.md); silently
  // wiping a dev's whole rating history the moment they're deleted would
  // destroy exactly the historical data this table exists to preserve.
  // devService.deleteDev surfaces this as a clear warning instead of letting
  // it surface as a raw FK constraint error.
  dev  Dev  @relation(fields: [devId], references: [id])
  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([devId])
  @@index([taskId])
  @@map("ratings_history")
}

// Deviates from docs/01-data-model.md in two ways, both required by the
// LLM-bypass mechanism in docs/05-vault-and-security.md:
// 1. secretValueEncrypted is nullable — metadata is created first via chat
//    (confirm-before-commit, like every other entity), and the secret value
//    is attached afterward through the dedicated widget/endpoint. A row with
//    a null value is simply "awaiting its secret."
// 2. file_attachment_url (a URL string) doesn't fit the doc's own storage
//    decision to keep encrypted file bytes directly in Postgres rather than
//    a second file-storage provider — replaced with fileName/fileMimeType/
//    fileBytesEncrypted so there's no external URL to point at.
// Each Bytes column holds a single self-describing blob: 12-byte IV +
// 16-byte auth tag + ciphertext, concatenated (see lib/vaultCrypto.ts) —
// avoids extra iv/tag columns per the doc's "document whichever you choose"
// allowance.
model VaultItem {
  id                   String   @id @default(uuid())
  name                 String
  folder               String?
  tags                 String[]
  secretValueEncrypted Bytes?   @map("secret_value_encrypted")
  notes                String?
  fileName             String?  @map("file_name")
  fileMimeType         String?  @map("file_mime_type")
  fileBytesEncrypted   Bytes?   @map("file_bytes_encrypted")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  @@index([folder])
  @@map("vault_items")
}

enum ReminderChannel {
  PUSH
  WHATSAPP
}

// docs/01-data-model.md flags fire_times as a candidate for normalization into
// a child table so each occurrence can track sent/cancelled independently —
// implemented that way here (ReminderOccurrence), per the doc's own recommendation.
model Reminder {
  id              String          @id @default(uuid())
  linkedTaskId    String?         @map("linked_task_id")
  linkedProjectId String?         @map("linked_project_id")
  message         String
  channel         ReminderChannel @default(PUSH)
  createdAt       DateTime        @default(now()) @map("created_at")

  linkedTask    Task?                @relation(fields: [linkedTaskId], references: [id])
  linkedProject Project?             @relation(fields: [linkedProjectId], references: [id])
  occurrences   ReminderOccurrence[]

  @@index([linkedTaskId])
  @@index([linkedProjectId])
  @@map("reminders")
}

enum ReminderOccurrenceStatus {
  SCHEDULED
  SENT
  CANCELLED
}

model ReminderOccurrence {
  id         String                   @id @default(uuid())
  reminderId String                   @map("reminder_id")
  fireTime   DateTime                 @map("fire_time")
  status     ReminderOccurrenceStatus @default(SCHEDULED)

  reminder Reminder @relation(fields: [reminderId], references: [id], onDelete: Cascade)

  @@index([status, fireTime])
  @@index([reminderId])
  @@map("reminder_occurrences")
}

enum AuditActionType {
  CREATE
  EDIT
  DELETE
}

enum AuditSource {
  CHAT
  DASHBOARD
}

model AuditLog {
  id         String          @id @default(uuid())
  actionType AuditActionType @map("action_type")
  entityType String          @map("entity_type")
  entityId   String          @map("entity_id")
  summary    String
  diff       Json?
  source     AuditSource
  createdAt  DateTime        @default(now()) @map("created_at")

  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_log")
}

enum ChatRole {
  USER
  AGENT
}

model ChatMessage {
  id              String   @id @default(uuid())
  role            ChatRole
  content         String
  linkedEntityIds String[] @map("linked_entity_ids")
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("chat_messages")
}

model Setting {
  key   String @id
  value String

  @@map("settings")
}

// ---------------------------------------------------------------------------
// Agent orchestration (not in docs/01-data-model.md — added in Phase 2)
// ---------------------------------------------------------------------------

// A write the agent has proposed but not yet executed, sitting between
// "summarize" and "wait for confirm" in the confirm-before-commit loop
// (docs/03-agent-and-llm.md). Persisted rather than kept in memory so an
// in-progress confirmation survives a Render cold restart.
model PendingAction {
  id        String   @id @default(uuid())
  toolName  String   @map("tool_name")
  args      Json
  summary   String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("pending_actions")
}

// Bridges a QA send-back to the replacement task's creation (Phase 3,
// docs/04-workflows.md "Sent Back" flow): resolve_qa_entry(SENT_BACK) writes
// one row here; the very next create_task consumes it to set
// supersedes_task_id / superseded_by_task_id server-side, with nothing
// pre-filled and no special-cased tool call — same pattern as PendingAction.
model PendingSupersession {
  id             String   @id @default(uuid())
  originalTaskId String   @map("original_task_id")
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("pending_supersessions")
}

// Marks that the system itself asked a specific yes/no question about a
// specific task and is waiting on the answer — e.g. the deadline-miss
// question in mark_task_done. Prevents the LLM from supplying that field on
// its own initiative by pattern-matching an unrelated prior exchange in
// conversation history (observed in testing): a value is only trusted if a
// matching row here is consumed in the same call.
model PendingClarification {
  id        String   @id @default(uuid())
  taskId    String   @map("task_id")
  field     String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("pending_clarifications")
}

// Holds the rest of a multi-entity request ("add devs A, B, C, D, all
// permanent") once every item is fully resolved — item 1 becomes the active
// PendingAction as usual, items 2..N sit here in order. Consuming one (on
// confirm OR cancel of the current PendingAction) promotes the next item to
// a fresh PendingAction automatically, so the user works through the whole
// batch one confirmation at a time without re-typing anything.
model PendingBatchQueue {
  id           String   @id @default(uuid())
  order        Int
  position     Int // 1-indexed display position within the original batch
  total        Int // total item count in the original batch
  toolName     String   @map("tool_name")
  resolvedArgs Json     @map("resolved_args")
  summary      String
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("pending_batch_queue")
}
